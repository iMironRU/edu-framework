{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/iMironRU/edu-framework/standards/fgos/schema/fgos.schema.json",
  "title": "ФГОС",
  "description": "JSON Schema для машиночитаемого представления Федерального государственного образовательного стандарта (ФГОС)",
  "type": "object",
  "required": [
    "meta",
    "program",
    "competencies",
    "structure"
  ],
  "properties": {

    "meta": {
      "type": "object",
      "description": "Реквизиты и идентификация стандарта",
      "required": ["id", "type", "level", "order_number", "order_date", "effective_date", "version"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Уникальный идентификатор в формате FGOS-<уровень>-<укснр>",
          "pattern": "^FGOS-(VO|SPO|OO|DO|DPO)-[0-9]{2}\\.[0-9]{2}\\.[0-9]{2}(-[0-9]+)?$",
          "examples": ["FGOS-VO-44.03.04", "FGOS-SPO-09.02.07"]
        },
        "type": {
          "type": "string",
          "description": "Тип стандарта",
          "enum": ["VO", "SPO", "OO", "DO", "DPO"],
          "enumDescriptions": [
            "Высшее образование",
            "Среднее профессиональное образование",
            "Общее образование",
            "Дополнительное образование",
            "Дополнительное профессиональное образование"
          ]
        },
        "level": {
          "type": "string",
          "description": "Уровень образования",
          "enum": [
            "bachelor",
            "specialist",
            "master",
            "postgraduate",
            "spo_base",
            "spo_advanced"
          ],
          "enumDescriptions": [
            "Бакалавриат",
            "Специалитет",
            "Магистратура",
            "Аспирантура / адъюнктура",
            "СПО: подготовка квалифицированных рабочих",
            "СПО: подготовка специалистов среднего звена"
          ]
        },
        "ugsn_code": {
          "type": "string",
          "description": "Код УГСН (укрупнённая группа специальностей и направлений)",
          "pattern": "^[0-9]{2}\\.[0-9]{2}\\.[0-9]{2}$",
          "examples": ["44.03.04", "09.02.07"]
        },
        "ugsn_name": {
          "type": "string",
          "description": "Наименование направления подготовки / специальности"
        },
        "order_number": {
          "type": "string",
          "description": "Номер приказа Минобрнауки / Минпросвет об утверждении"
        },
        "order_date": {
          "type": "string",
          "format": "date",
          "description": "Дата приказа"
        },
        "effective_date": {
          "type": "string",
          "format": "date",
          "description": "Дата вступления в силу"
        },
        "version": {
          "type": "string",
          "description": "Поколение ФГОС",
          "enum": ["3", "3+", "3++"],
          "default": "3++"
        },
        "supersedes": {
          "type": "string",
          "description": "ID предыдущего стандарта, который данный стандарт заменяет"
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "Ссылка на официальный текст стандарта (fgosvo.ru / consultant.ru)"
        }
      }
    },

    "program": {
      "type": "object",
      "description": "Характеристики образовательной программы",
      "required": ["qualification", "duration_years", "volume_credits"],
      "properties": {
        "qualification": {
          "type": "string",
          "description": "Квалификация (степень) выпускника",
          "examples": ["Бакалавр", "Специалист", "Магистр", "Исследователь. Преподаватель-исследователь"]
        },
        "forms": {
          "type": "array",
          "description": "Допустимые формы обучения",
          "items": {
            "type": "string",
            "enum": ["full_time", "part_time", "distance"]
          }
        },
        "duration_years": {
          "type": "object",
          "description": "Нормативный срок обучения по формам (в годах)",
          "properties": {
            "full_time": { "type": "number" },
            "part_time": { "type": "number" },
            "distance": { "type": "number" }
          }
        },
        "volume_credits": {
          "type": "integer",
          "description": "Объём программы в зачётных единицах (з.е.)"
        },
        "profile_types": {
          "type": "array",
          "description": "Возможные профили / специализации (если предусмотрены стандартом)",
          "items": { "type": "string" }
        }
      }
    },

    "competencies": {
      "type": "object",
      "description": "Компетенции выпускника",
      "required": ["universal", "general_professional"],
      "properties": {
        "universal": {
          "type": "array",
          "description": "Универсальные компетенции (УК)",
          "items": { "$ref": "#/$defs/competency" }
        },
        "general_professional": {
          "type": "array",
          "description": "Общепрофессиональные компетенции (ОПК)",
          "items": { "$ref": "#/$defs/competency" }
        },
        "professional": {
          "type": "array",
          "description": "Профессиональные компетенции (ПК) — если установлены стандартом",
          "items": { "$ref": "#/$defs/competency" }
        }
      }
    },

    "structure": {
      "type": "object",
      "description": "Структура программы (блоки и их объём)",
      "required": ["blocks"],
      "properties": {
        "blocks": {
          "type": "array",
          "description": "Блоки программы (Блок 1 — Дисциплины; Блок 2 — Практики; и т.д.)",
          "items": { "$ref": "#/$defs/program_block" }
        },
        "state_exam": {
          "type": "boolean",
          "description": "Государственный экзамен предусмотрен стандартом"
        },
        "thesis": {
          "type": "boolean",
          "description": "Выпускная квалификационная работа предусмотрена стандартом"
        }
      }
    },

    "requirements": {
      "type": "object",
      "description": "Требования к условиям реализации программы",
      "properties": {
        "staff": {
          "type": "object",
          "description": "Требования к кадровым условиям",
          "properties": {
            "phd_share_min": {
              "type": "number",
              "description": "Минимальная доля ППС с учёной степенью / званием (%)"
            },
            "practice_share_min": {
              "type": "number",
              "description": "Минимальная доля ППС из числа действующих практиков (%)"
            }
          }
        },
        "material": {
          "type": "object",
          "description": "Требования к материально-техническому обеспечению",
          "properties": {
            "notes": {
              "type": "string",
              "description": "Свободное описание требований МТБ"
            }
          }
        }
      }
    }
  },

  "$defs": {
    "competency": {
      "type": "object",
      "required": ["code", "name"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Код компетенции",
          "examples": ["УК-1", "ОПК-3", "ПК-5"]
        },
        "name": {
          "type": "string",
          "description": "Формулировка компетенции"
        },
        "category": {
          "type": "string",
          "description": "Категория (для УК — по ФГОС 3++)",
          "examples": ["Системное и критическое мышление", "Командная работа и лидерство"]
        }
      }
    },
    "program_block": {
      "type": "object",
      "required": ["code", "name", "volume_credits"],
      "properties": {
        "code": {
          "type": "string",
          "examples": ["Б1", "Б2", "Б3", "ФТД"]
        },
        "name": {
          "type": "string",
          "examples": ["Дисциплины (модули)", "Практика", "Государственная итоговая аттестация"]
        },
        "volume_credits": {
          "type": "integer",
          "description": "Объём блока в з.е."
        },
        "mandatory_part_credits": {
          "type": "integer",
          "description": "Объём обязательной части в з.е."
        },
        "elective_part_credits": {
          "type": "integer",
          "description": "Объём части, формируемой участниками образовательных отношений, в з.е."
        }
      }
    }
  }
}
