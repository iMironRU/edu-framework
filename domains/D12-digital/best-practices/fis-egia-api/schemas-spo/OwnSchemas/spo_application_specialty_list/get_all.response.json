               },
               "id_object": {
                  "$ref": "#/definitions/int8",
                  "description": "Уникальный идентификатор объекта в рамках токена"
               },
               "description": {
                  "$ref": "#/definitions/string350",
                  "description": "Описание ошибки"
               },
               "params": {
                  "type": [
                     "array",
                     "null"
                  ],
                  "items": {
                     "type": "object",
                     "additionalProperties": {
                        "type": "null"
                     },
                     "properties": {
                        "key": {
                           "$ref": "#/definitions/string50"
                        },
                        "value": {
                           "$ref": "#/definitions/string350"
                        }
                     },
                     "required": [
                        "key",
                        "value"
                     ]
                  }
               },
               "time": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Время формирования ответа"
               }
            },
            "required": [
               "code",
               "description",
               "time"
            ]
         }
      }
   },
   "required": [
      "id_jwt",
      "entity_action",
      "stage"
