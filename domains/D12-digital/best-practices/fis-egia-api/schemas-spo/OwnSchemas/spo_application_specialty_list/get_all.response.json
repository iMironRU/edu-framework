   "definitions": {
      "int8": {
         "type": "integer",
         "minimum": 1,
         "maximum": 9223372036854776000
      },
      "int4": {
         "type": "integer",
         "minimum": 1,
         "maximum": 2147483647
      },
      "string50": {
         "type": "string",
         "minLength": 1,
         "maxLength": 50
      },
      "string200": {
         "type": "string",
         "minLength": 1,
         "maxLength": 200
      },
      "string350": {
         "type": "string",
         "minLength": 1,
         "maxLength": 350
      },
      "stage_type": {
         "type": "string",
         "enum": [
            "validate",
            "business"
         ]
      }
   }
