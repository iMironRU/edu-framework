{
   "description": "Список льгот в рамках заявлений поступающего (сущность)",
   "type": "object",
   "additionalProperties": { "type": "null" },
   "properties": {
      "id_jwt": {
         "$ref": "#/definitions/int8",
         "description": "Уникальный идентификатор запроса на обработку данных (токена)"
      },
      "entity_action": {
         "$ref": "#/definitions/string50",
         "description": "Имя сущности и действие над сущностью сконкатенированное через '.'. Например \"spo_сampaign_list.add\""
      },
      "stage": {
         "$ref": "#/definitions/stage",
         "description": "Наименование стадии обработки на которой завершилось выполнение токена"
      },
      "success_result_list": {
         "type": [
            "array",
            "null"
         ],
         "items": {
            "type": "object",
            "additionalProperties": { "type": "null" },
            "properties": {
               "id_object": {
                  "$ref": "#/definitions/int8",
                  "description": "Уникальный идентификатор объекта в рамках данного токена"
               },
               "id_application": {
                  "$ref": "#/definitions/int8",
                  "description": "Уникальный идентификатор заявления"
               },
               "benefit_list": {
                  "type": "array",
                  "items": {
                     "type": "object",
                     "additionalProperties": { "type": "null" },
                     "properties": {
                        "id_benefit": {
                           "$ref": "#/definitions/int4",
                           "description": "Идентификатор классификатора benefit_cls"
                        },
                        "file_list": {
                           "type": "array",
                           "items": {
                              "type": "object",
                              "additionalProperties": { "type": "null" },
                              "properties": {
                                 "fui": {
                                    "type": "string",
                                    "description": "Уникальный идентификатор файла в Сервисе Приема"
                                 },
                                 "file_hash": {
                                    "type": "string",
                                    "description": "Хэш файла"
                                 }
                              },
                              "required": [
                                 "fui",
                                 "file_hash"
                              ]
                           }
                        }
                     },
                     "required": [
                        "id_benefit"
                     ]
                  }
               }
            },
            "required": [
               "id_object",
               "id_application"
            ]
         }
      },
      "error_list": {
         "type": [
            "array",
            "null"
         ],
         "items": {
            "type": "object",
            "additionalProperties": { "type": "null" },
            "properties": {
               "code": {
                  "$ref": "#/definitions/int8",
                  "description": "Уникальный код ошибки"
               },
               "id_object": {
                  "$ref": "#/definitions/int8",
                  "description": "Уникальный идентификатор объекта в рамках токена"
               },
               "description": {
                  "$ref": "#/definitions/string350",
                  "description": "Описание ошибки"
               },
               "params": {
                  "type": [
                     "array",
                     "null"
                  ],
                  "items": {
                     "type": "object",
                     "additionalProperties": { "type": "null" },
                     "properties": {
                        "key": {
                           "$ref": "#/definitions/string50"
                        },
                        "value": {
                           "$ref": "#/definitions/string350"
                        }
                     },
                     "required": [
                        "key",
                        "value"
                     ]
                  }
               },
               "time": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Время формирования ответа"
               }
            },
            "required": [
               "code",
               "description",
               "time"
            ]
         }
      }
   },
   "required": [
      "id_jwt",
      "entity_action",
      "stage"
   ],
   "definitions": {
      "int8": {
         "type": "integer",
         "minimum": 1,
         "maximum": 9223372036854775807
      },
      "int4": {
         "type": "integer",
         "minimum": 1,
         "maximum": 2147483647
      },
      "stage": {
         "type": "string",
         "enum": [
            "validate",
            "business"
         ]
      },
      "string50": {
         "type": "string",
         "minLength": 1,
         "maxLength": 50
      },
      "string200": {
         "type": "string",
         "minLength": 1,
         "maxLength": 200
      },
      "string350": {
         "type": "string",
         "minLength": 1,
         "maxLength": 350
      },
      "snils_type": {
         "type": "string",
         "pattern": "^\\d{11}$",
         "description": "СНИЛС"
      }
   }
}